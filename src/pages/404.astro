---
import Layout from '../layouts/Layout.astro';
---

<Layout title="404 - Page Not Found">
  <main class="max-w-5xl mx-auto px-6 py-24 flex-grow flex flex-col items-center justify-center text-center">
    <h1 class="text-6xl font-black text-slate-900 mb-4">404</h1>
    <p class="text-xl text-slate-600 mb-8">
      <span class="lang-cn">页面未找到</span>
      <span class="lang-en">Page Not Found</span>
    </p>
    <a href="/" class="px-6 py-3 bg-blue-600 text-white rounded-lg hover:bg-blue-700 transition-colors">
      <span class="lang-cn">返回首页</span>
      <span class="lang-en">Back to Home</span>
    </a>
  </main>
</Layout>
