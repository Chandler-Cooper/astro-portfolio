---
interface Props {
  titleCn: string;
  titleEn: string;
  orgCn: string;
  orgEn: string;
  time: string;
  tags: string[];
  contextCn: string;
  contextEn: string;
  roleCn?: string;
  roleEn?: string;
  methodologyCn: string;
  methodologyEn: string;
  impactCn: string;
  impactEn: string;
  linkUrl?: string;
  linkTextCn?: string;
  linkTextEn?: string;
}

const {
  titleCn, titleEn, orgCn, orgEn, time, tags,
  contextCn, contextEn, roleCn, roleEn,
  methodologyCn, methodologyEn, impactCn, impactEn,
  linkUrl, linkTextCn, linkTextEn
} = Astro.props;
---

<div class="bg-white p-6 rounded-2xl shadow-sm border border-slate-100 hover:shadow-md transition-all duration-300 hover:-translate-y-1">
  <!-- 标题行 -->
  <div class="flex flex-col md:flex-row md:justify-between md:items-start mb-4">
    <div>
      <h3 class="text-xl font-bold text-slate-900 leading-tight">
        <span class="lang-cn">{titleCn}</span>
        <span class="lang-en">{titleEn}</span>
      </h3>
      <p class="text-blue-600 font-semibold mt-1">
        <span class="lang-cn">{orgCn}</span>
        <span class="lang-en">{orgEn}</span>
      </p>
    </div>
    <span class="text-slate-400 text-sm mt-2 md:mt-0 font-mono whitespace-nowrap">{time}</span>
  </div>

  <!-- 标签云 -->
  <div class="flex flex-wrap gap-2 mb-4">
    {tags.map((tag) => (
      <span class="px-2.5 py-0.5 bg-slate-100 text-slate-600 text-xs font-medium rounded-full">
        {tag}
      </span>
    ))}
  </div>

  <!-- 正文内容 -->
  <div class="space-y-3 text-slate-600 text-sm leading-relaxed whitespace-pre-line text-justify">
    {roleCn && (
      <p>
        <strong class="text-slate-800">
          <span class="lang-cn">职责：</span><span class="lang-en">Role: </span>
        </strong>
        <span class="lang-cn">{roleCn}</span><span class="lang-en">{roleEn}</span>
      </p>
    )}
    <p>
      <strong class="text-slate-800">
        <span class="lang-cn">背景：</span><span class="lang-en">Context: </span>
      </strong>
      <span class="lang-cn">{contextCn}</span><span class="lang-en">{contextEn}</span>
    </p>
    <p>
      <strong class="text-slate-800">
        <span class="lang-cn">方法：</span><span class="lang-en">Methodology: </span>
      </strong>
      <span class="lang-cn">{methodologyCn}</span><span class="lang-en">{methodologyEn}</span>
    </p>
    
    <!-- 【重点检查区】确保这里只有这一块蓝色方框代码 -->
    <div class="bg-blue-50/50 p-3 rounded-lg border-l-4 border-blue-500 mt-4 shadow-sm">
      <strong class="text-slate-900 block mb-1">
        <span class="lang-cn">成果/影响：</span><span class="lang-en">Impact: </span>
      </strong>
      <div class="text-slate-700 font-medium">
        <span class="lang-cn">{impactCn}</span><span class="lang-en">{impactEn}</span>
      </div>
    </div>
  </div>

  <!-- 底部链接按钮 -->
  {linkUrl && (
    <div class="mt-5 pt-4 border-t border-slate-100 flex justify-end">
      <a href={linkUrl} target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-sm font-bold text-blue-600 hover:text-blue-800 transition-colors group">
        <span class="lang-cn">{linkTextCn}</span>
        <span class="lang-en">{linkTextEn}</span>
        <svg class="w-4 h-4 group-hover:translate-x-0.5 group-hover:-translate-y-0.5 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
        </svg>
      </a>
    </div>
  )}
</div>