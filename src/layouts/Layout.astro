---
import '../styles/global.css'; // 👈 加上这一行，引入你项目中的全局样式表！

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Xinxin Li's Personal Portfolio" } = Astro.props;
---

<!doctype html>
<html lang="zh-CN" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
  </head>
  <body class="bg-slate-50 text-slate-800 font-sans antialiased min-h-screen flex flex-col">
    <slot />

    <!-- 全局双语切换脚本 -->
    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('lang-toggle');
        const toggleText = document.getElementById('lang-toggle-text');
        
        const currentLang = localStorage.getItem('lang') || 'cn';
        if (currentLang === 'en') {
          document.documentElement.classList.add('en');
          if (toggleText) toggleText.textContent = '中文';
        }

        toggleBtn?.addEventListener('click', () => {
          const isEn = document.documentElement.classList.toggle('en');
          document.documentElement.lang = isEn ? 'en' : 'zh-CN';
          localStorage.setItem('lang', isEn ? 'en' : 'cn');
          if (toggleText) toggleText.textContent = isEn ? '中文' : 'English';
        });
      });
    </script>

    <!-- 双语显示 CSS 控制规则 -->
    <style is:global>
      /*  👇 在这里添加你喜欢的全局字体样式 */
      html, body {
        font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, "PingFang SC", "Hiragino Sans GB", "Microsoft YaHei", sans-serif !important;
      }

	  .lang-en { display: none !important; }
      .lang-cn { display: block; }
      span.lang-cn { display: inline !important; }

      html.en .lang-cn { display: none !important; }
      html.en .lang-en { display: block !important; }
      html.en span.lang-en { display: inline !important; }
    </style>
  </body>
</html>
